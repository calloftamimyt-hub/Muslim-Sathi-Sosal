rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helper Primitives
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Identity check against trusted admin collection or specific verified emails
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email.matches(".*its.me.calloftamim@gmail.com")
      );
    }

    // ===============================================================
    // Entity Validation Helpers
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['updatedAt']) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('username' in data) || (data.username is string && data.username.size() <= 50)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('role' in data) || data.role in ['admin', 'client']) &&
             data.updatedAt == request.time;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'authorName', 'content', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt == request.time;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'userUid', 'userName', 'content', 'createdAt']) &&
             data.userUid == request.auth.uid &&
             data.content is string && data.content.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidEarningHistory(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt == request.time;
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'method', 'amount', 'phoneNumber', 'accountName', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    // ... additional helpers for all collections ...

    // ===============================================================
    // Collection Match Blocks
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || !resource.data.keys().hasAny(['email', 'phoneNumber']));
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Secure List Pillar
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'username', 'photoURL', 'location', 'updatedAt'])) || isAdmin();
      
      match /daily_stats/{dateStr} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /earning_history/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidEarningHistory(incoming());
      }
    }

    match /posts/{postId} {
      allow get: if isSignedIn() && isValidId(postId);
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidPost(incoming());
      allow update: if (isSignedIn() && (
        (isOwner(existing().authorUid) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['reactionsCount', 'ameenCount', 'reportsCount']))
      )) || isAdmin();
      allow delete: if isOwner(existing().authorUid) || isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow create: if isVerified() && isValidWithdrawal(incoming());
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ... complete the rest of the matches ...

  }
}
